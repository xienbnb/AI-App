# ===== 部署配置示例 =====
# 复制此文件为 .env 并填入你的实际值

# Supabase REST API 地址（用于 Auth 登录认证）
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key（公开密钥，在 Settings → API 中获取）
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service_role key（可选，用于管理操作）
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# PostgreSQL 直接连接串（用于 Drizzle ORM 读写数据）
# 可从 Supabase → Settings → Database → Connection string → URI 获取
DATABASE_URL=postgresql://postgres:your_password@db.your-project.supabase.co:5432/postgres?sslmode=require